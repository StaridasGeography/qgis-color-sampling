  <defaults>
    <default field="H" applyOnUpdate="1" expression="with_variable('r', raster_value(@source_map, 1, @geometry),&#xd;&#xa;with_variable('g', raster_value(@source_map, 2, @geometry),&#xd;&#xa;with_variable('b', raster_value(@source_map, 3, @geometry),&#xd;&#xa;with_variable('cmax', max(@r, @g, @b),&#xd;&#xa;with_variable('cmin', min(@r, @g, @b),&#xd;&#xa;with_variable('chroma', @cmax - @cmin,&#xd;&#xa;with_variable('hprime',&#xd;&#xa;case&#xd;&#xa;when @chroma = 0 then 0&#xd;&#xa;when @cmax = @r then (@g - @b) / @chroma&#xd;&#xa;when @cmax = @g then ((@b - @r) / @chroma) + 2&#xd;&#xa;else ((@r - @g) / @chroma) + 4&#xd;&#xa;end,&#xd;&#xa;((@hprime * 60) + 360) % 360&#xd;&#xa;)))))))"/>
