    <default field="V" applyOnUpdate="1" expression="with_variable('r', raster_value(@source_map, 1, @geometry),&#xd;&#xa;with_variable('g', raster_value(@source_map, 2, @geometry),&#xd;&#xa;with_variable('b', raster_value(@source_map, 3, @geometry),&#xd;&#xa;(max(@r, @g, @b) * 100) / 255&#xd;&#xa;)))"/>
    <default field="R" applyOnUpdate="1" expression="raster_value(@source_map, 1, @geometry)"/>
    <default field="G" applyOnUpdate="1" expression="raster_value(@source_map, 2, @geometry)"/>
